{
  "name": "json-diff",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "bun@1.2.2",
  "scripts": {
    "dev": "vite",
    "build": "bun run paraglide:compile && tsc -b && vite build",
    "paraglide:compile": "bunx @inlang/paraglide-js compile --project ./project.inlang --outdir ./src/paraglide --strategy localStorage cookie baseLocale",
    "preview": "vite preview",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "ajv": "^8.20.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "shadcn": "^4.11.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@inlang/paraglide-js": "^2.20.2",
    "@tailwindcss/vite": "^4.1.11",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "husky": "^9.1.7",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.8.3",
    "vite": "^7.0.4"
  }
}
